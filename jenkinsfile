pipeline {
    agent any

    stages {
        stage('Hello') {
            agent {
                docker {
                    image 'node:20-alpine'
                }
            }
            steps {
                sh '''
                    echo "Steps initialized here"
                    echo node -version
                    echo npm -version
                    npm ci
                    npm run build
                    echo "Build completed successfully"
                '''
            }
        }
    }
}
