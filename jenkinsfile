pipeline {
    agent any

    stages {
        stage('build') {
            agent {
                docker {
                    image 'node:18-alpine'
                    reuseNode true
                }
            }
            steps {
                sh '''
                    echo "Steps initialized here"
                    echo node -version
                    echo npm -version
                    npm ci
                    npm run build
                    echo "Build completed successfully"
                '''
            }
        }
        stage('test') {
            agent {
                docker {
                    image 'node:18-alpine'
                    reuseNode true
                }
            }
            steps {
                sh '''
                    echo "Testing phase initialized here"
                    test -f ./build/index.html
                    npm run test
                    echo "Testing phase completed successfully"
                '''
            }
        }
    }
    
    post {
            always {
                echo "Cleaning up workspace"
                junit ./test-results/junit.xml
            }
        }
}
