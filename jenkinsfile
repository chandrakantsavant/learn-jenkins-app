pipeline {
    agent any
    environment {
        NETLIFY_SITE_ID = '10cbe470-80c2-40c8-8aaf-3cbe7e22b9ae'
        NETLIFY_AUTH_TOKEN = credentials('netlify-token')
    }
    stages {
        // Single line comment example -
        // This is build stage where we will build the application using Node.js and npm.
        stage('build') {
            agent {
                docker {
                    image 'node:18-bookworm'
                    reuseNode true
                }
            }
            steps {
                sh '''
                    echo "Steps initialized here"
                    node --version
                    npm --version
                    npm ci
                    npm run build
                    echo "Build completed successfully"
                '''
            }
        }
        stage('Testing-Phase') {
            parallel {
                /*
                # Multi-line comment example -
                # This is test stage where we will run the tests for the application using Node.js and
                */
                stage('test') {
                    agent {
                        docker {
                            image 'node:18-bookworm'
                            reuseNode true
                        }
                    }
                    steps {
                        sh '''
                            echo "Testing phase initialized here"
                            test -f ./build/index.html
                            npm run test
                            echo "Testing phase completed successfully"
                        '''
                    }
                    post {
                        always {
                            junit 'jest-results/junit.xml'
                        }
                    }
                }
                // E2E test stage where we will run the end-to-end tests for the application using Cypress.
                stage('e2e-test') {
                    agent {
                        docker {
                            image 'mcr.microsoft.com/playwright:v1.39.0-jammy'
                            reuseNode true
                        }
                    }
                    steps {
                        sh '''
                            echo "E2E Testing phase initialized here"
                            npm install serve
                            npx playwright install chromium
                            node_modules/.bin/serve -s build &
                            sleep 10
                            npx playwright test --reporter=html
                            echo "E2E Testing phase completed successfully"
                        '''
                    }
                    post {
                        always {
                            publishHTML([allowMissing: false, alwaysLinkToLastBuild: false, icon: '', keepAll: false, reportDir: 'playwright-report', reportFiles: 'index.html', reportName: 'HTML Report Local', reportTitles: 'Test Report', useWrapperFileDirectly: true])
                        }
                    }
                }
            }
        }

        stage('Deploy Staging') {
            agent {
                docker {
                    image 'node:18-bookworm'
                    reuseNode true
                }
            }
            steps {
                sh '''
                    npm install netlify-cli
                    node_modules/.bin/netlify --version
                    echo "We are deploying to Netlify that has a Site Key: $NETLIFY_SITE_ID"
                    node_modules/.bin/netlify status
                    node_modules/.bin/netlify deploy --dir=build

                '''
            }
        }

        stage('Deploy Prod') {
            agent {
                docker {
                    image 'node:18-bookworm'
                    reuseNode true
                }
            }
            steps {
                sh '''
                    npm install netlify-cli
                    node_modules/.bin/netlify --version
                    echo "We are deploying to Netlify that has a Site Key: $NETLIFY_SITE_ID"
                    node_modules/.bin/netlify status
                    node_modules/.bin/netlify deploy --dir=build --prod

                '''
            }
        }

        stage('e2e-test-production') {
            agent {
                docker {
                    image 'mcr.microsoft.com/playwright:v1.39.0-jammy'
                    reuseNode true
                }
            }

            environment {
                CI_ENVIRONMENT_URL='https://profound-raindrop-2a6c17.netlify.app'
            }

            steps {
                sh '''
                    echo "E2E Testing phase for production initialized here"
                    npx playwright test --reporter=html
                    echo "E2E Testing production phase completed successfully"
                '''
            }
            post {
                always {
                    publishHTML([allowMissing: false, alwaysLinkToLastBuild: false, icon: '', keepAll: false, reportDir: 'playwright-report', reportFiles: 'index.html', reportName: 'HTML Report Production', reportTitles: 'Test Report', useWrapperFileDirectly: true])
                }
            }
        }
    }
}
